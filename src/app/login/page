"use client";
import React, { useState } from 'react';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL!, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!);

export default function SimpleLogin() {
  const [formData, setFormData] = useState({ email: '', password: '' });
  const [msg, setMsg] = useState('');

  const handleLogin = async (e: React.FormEvent) => {
    e.preventDefault();
    const { data, error } = await supabase
      .from('space_users')
      .select('*')
      .eq('email', formData.email)
      .eq('password', formData.password)
      .single();

    if (data) {
      localStorage.setItem('userEmail', data.email); // 临时持久化
      window.location.href = '/registry'; // 登录后跳转至地址申请页
    } else {
      setMsg("账号或密码错误");
    }
  };

  return (
    <div className="min-h-screen bg-black text-white font-mono flex items-center justify-center p-6">
      <form onSubmit={handleLogin} className="max-w-sm w-full border border-zinc-800 p-8 bg-zinc-900/30">
        <h2 className="text-xl font-bold mb-6 text-blue-500 uppercase italic">Login Portal</h2>
        <div className="space-y-4">
          <input required type="email" placeholder="Email" className="w-full bg-black border border-zinc-800 p-3 text-sm focus:border-blue-500 outline-none" 
            onChange={e => setFormData({...formData, email: e.target.value})} />
          <input required type="password" placeholder="Password" className="w-full bg-black border border-zinc-800 p-3 text-sm focus:border-blue-500 outline-none" 
            onChange={e => setFormData({...formData, password: e.target.value})} />
          {msg && <p className="text-[10px] text-red-500 uppercase">{msg}</p>}
          <button className="w-full py-3 bg-blue-600 text-white font-bold text-xs uppercase">Enter Terminal</button>
        </div>
      </form>
    </div>
  );
}